---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { site } from "../../../data/site";
const base = import.meta.env.BASE_URL;
const normalizeBase = (b) => (b === "/" ? "/" : b.endsWith("/") ? b : `${b}/`);
const href = (path) => `${normalizeBase(base)}${String(path).replace(/^\/+/, "")}`;
---
<BaseLayout title={`${site.name} · CV (EN)`} description="Curriculum Vitae (English)">
  <section class="hero" style="padding-bottom: 8px;">
    <h1>CV (English)</h1>
    <p>
      <a class="pill" href={href("/cv/")}>Overview</a>
      <a class="pill" href={href("/cv/zh/")}>中文</a>
      <a class="pill" href={href(site.cv.enPdf)}>Download PDF</a>
    </p>
  </section>

  <section class="section">
    <div class="card" style="padding: 0; overflow: hidden;">
      <iframe
        src={href(site.cv.enPdf)}
        title="CV PDF (EN)"
        style="width:100%; height: 1100px; border: none;"
      >
      </iframe>
    </div>
  </section>
</BaseLayout>

