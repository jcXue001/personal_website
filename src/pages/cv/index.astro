---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { site } from "../../data/site";
const base = import.meta.env.BASE_URL;
const normalizeBase = (b) => (b === "/" ? "/" : b.endsWith("/") ? b : `${b}/`);
const href = (path) => `${normalizeBase(base)}${String(path).replace(/^\/+/, "")}`;
---
<BaseLayout title={`${site.name} · CV`} description="Curriculum Vitae">
  <section class="hero" style="padding-bottom: 8px;">
    <h1>CV</h1>
    <p>
      Download: <a href={href("/files/CV_XUE_250808.pdf")}>CV_XUE_250808.pdf</a>
    </p>
  </section>

  <section class="section">
    <div class="card" style="padding: 0; overflow: hidden;">
      <iframe
        src={href("/files/CV_XUE_250808.pdf")}
        title="CV PDF"
        style="width:100%; height: 1100px; border: none;"
      >
      </iframe>
    </div>
  </section>
</BaseLayout>
