---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { site } from "../../data/site";
const base = import.meta.env.BASE_URL;
const normalizeBase = (b) => (b === "/" ? "/" : b.endsWith("/") ? b : `${b}/`);
const href = (path) => `${normalizeBase(base)}${String(path).replace(/^\/+/, "")}`;
---
<BaseLayout title={`${site.name} · CV`} description="Curriculum Vitae (EN/ZH)">
  <section class="hero" style="padding-bottom: 8px;">
    <h1>CV</h1>
    <p>
      <a class="pill" href={href("/cv/en/")}>English</a>
      <a class="pill" href={href("/cv/zh/")}>中文</a>
    </p>
    <p class="kicker">
      PDFs are expected at <code>{site.cv.enPdf}</code> and <code>{site.cv.zhPdf}</code>.
    </p>
  </section>

  <section class="section">
    <div class="card">
      <h2>Download</h2>
      <p>
        <a href={href(site.cv.enPdf)}>CV (EN)</a>
        {" · "}
        <a href={href(site.cv.zhPdf)}>CV (ZH)</a>
      </p>
    </div>
  </section>
</BaseLayout>

